# Copia este archivo a .env.local y llena los valores reales.
# Nunca commitear el archivo lleno — .env y .env.* (excepto este .example) están en .gitignore.
# Nunca poner ninguno de estos valores directamente en CLAUDE.md, SETUP_CHECKLIST.md, TASKS.md,
# o cualquier archivo bajo .claude/skills/ — esos archivos se commitean; este no.

# --- Conexión de la app a Supabase (src/lib/supabase.js) ---
# Desde 2026-07-20 ya NO están hardcodeadas en el código — se leen de estas dos variables.
# En LOCAL: siempre el proyecto SANDBOX (top-tennis-performance-academy-sandbox,
#   ref xchdawwajmnnhkncikig) — nunca producción, para que correr `npm run dev` o hacer un
#   walkthrough de UI no toque datos reales de atletas.
# En VERCEL (producción): estas dos variables se configuran en Settings → Environment
#   Variables con las credenciales del proyecto de PRODUCCIÓN (rrrwhwciggohwxslqlho) —
#   nunca en un archivo del repo. Sin esto, la app no arranca (falla explícito, a propósito).
VITE_SUPABASE_URL=https://xchdawwajmnnhkncikig.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_A7kK_tXIZ3goBQDIGUku7g_8mGCcf8i

# --- Frontend (Vite) ---
# Invite codes para registro de coach/atleta desde el portal.
VITE_COACH_INVITE_CODE=
VITE_CONTENT_INVITE_CODE=

# --- Supabase producción (proyecto: top-tennis-performance-academy, ref: rrrwhwciggohwxslqlho) ---
# El secret key NUNCA debe vivir en el frontend ni en este repo salvo como GitHub Secret:
# ya está configurado ahí para el cron de amtp-rankings-cron.yml. Si necesitas correr el scraper
# localmente (scripts/amtp_scraper.py), define estas dos variables solo en tu shell/entorno local:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Contraseña de conexión directa a Postgres (para psql, Supabase CLI `db push`, etc.) —
# NUNCA en un archivo commiteado (ver docs/db-schema.md, que tuvo esta fuga hasta 2026-07-17).
SUPABASE_DB_PASSWORD_PROD=

# --- Supabase sandbox (proyecto: top-tennis-performance-academy-sandbox, ref: xchdawwajmnnhkncikig) ---
# Mismas credenciales que VITE_SUPABASE_URL/VITE_SUPABASE_ANON_KEY arriba, más las variables
# que hacen falta para trabajar con el CLI de Supabase (migraciones, `db push`/`db pull`) en
# vez de solo MCP:
SUPABASE_URL_SANDBOX=https://xchdawwajmnnhkncikig.supabase.co
SUPABASE_PUBLISHABLE_KEY_SANDBOX=sb_publishable_A7kK_tXIZ3goBQDIGUku7g_8mGCcf8i
SUPABASE_SERVICE_KEY_SANDBOX=
SUPABASE_DB_PASSWORD_SANDBOX=

# --- Edge Function generate-quarterly-plan (Supabase Edge Functions / Deno) ---
# Esta variable se configura como secret de la función en Supabase, no en este .env del repo raíz.
# Se documenta aquí solo para que quede claro que existe y de dónde sale.
OPENAI_API_KEY=

# --- scripts/onboarding_digest.mjs (T161 Parte 2) ---
# En CI (.github/workflows/onboarding-digest-cron.yml): SUPABASE_URL/SUPABASE_SERVICE_KEY
# apuntan a PRODUCCIÓN (mismos GitHub Secrets que ya usa amtp-rankings-cron.yml) — el digest
# es para coaches reales sobre atletas reales. RESEND_API_KEY también vive solo como GitHub
# Secret. Para correrlo localmente con --dry-run, exporta SUPABASE_URL/SUPABASE_SERVICE_KEY
# apuntando al SANDBOX en tu shell (ver bloque de arriba), nunca los dejes fijos acá.
RESEND_API_KEY=
RESEND_FROM=
# Si se llena, el digest se manda SOLO a este email en vez de a todos los coaches — para
# probar un envío real (vía workflow_dispatch en GitHub Actions, input "test_to").
DIGEST_TEST_TO=
