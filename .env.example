# Copia este archivo a .env.local y llena los valores reales.
# Nunca commitear el archivo lleno — .env y .env.* (excepto este .example) están en .gitignore.
# Nunca poner ninguno de estos valores directamente en CLAUDE.md, SETUP_CHECKLIST.md, TASKS.md,
# o cualquier archivo bajo .claude/skills/ — esos archivos se commitean; este no.

# --- Frontend (Vite) ---
# Invite codes para registro de coach/atleta desde el portal.
VITE_COACH_INVITE_CODE=
VITE_CONTENT_INVITE_CODE=

# --- Supabase (proyecto: top-tennis-performance-academy, ref: rrrwhwciggohwxslqlho) ---
# El publishable key vive hardcodeado en src/lib/supabase.js (es público por diseño, protegido por RLS).
# El secret key NUNCA debe vivir en el frontend ni en este repo salvo como GitHub Secret:
# ya está configurado ahí para el cron de amtp-rankings-cron.yml. Si necesitas correr el scraper
# localmente (scripts/amtp_scraper.py), define estas dos variables solo en tu shell/entorno local:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Contraseña de conexión directa a Postgres (para psql, Supabase CLI `db push`, etc.) —
# NUNCA en un archivo commiteado (ver docs/db-schema.md, que tuvo esta fuga hasta 2026-07-17).
SUPABASE_DB_PASSWORD_PROD=

# --- Supabase sandbox (proyecto: top-tennis-performance-academy-sandbox, ref: xchdawwajmnnhkncikig) ---
# Entorno de desarrollo/pruebas — apunta aquí en local, nunca a producción.
SUPABASE_URL_SANDBOX=https://xchdawwajmnnhkncikig.supabase.co
SUPABASE_PUBLISHABLE_KEY_SANDBOX=sb_publishable_A7kK_tXIZ3goBQDIGUku7g_8mGCcf8i
SUPABASE_SERVICE_KEY_SANDBOX=
SUPABASE_DB_PASSWORD_SANDBOX=

# --- Edge Function generate-quarterly-plan (Supabase Edge Functions / Deno) ---
# Esta variable se configura como secret de la función en Supabase, no en este .env del repo raíz.
# Se documenta aquí solo para que quede claro que existe y de dónde sale.
OPENAI_API_KEY=

# --- Nota sobre sandbox ---
# Hoy no existe un proyecto Supabase separado de dev/sandbox — todo (frontend, Edge Functions,
# scraper) apunta al único proyecto de producción (rrrwhwciggohwxslqlho). Ver SETUP_CHECKLIST.md
# sección 4 para la decisión pendiente sobre esto.
