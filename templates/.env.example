# Copy this file to .env.local and fill in real values — .env.local is the file Vite (and most
# frontend tooling) actually auto-loads and treats as git-ignorable by convention. Don't invent
# other names like ".env.dev"; that's not a real convention and nothing will load it automatically.
# Never put real values in plain ".env" either — a bare ".env" is easy to commit by accident
# (that's exactly what happened once already) and isn't the file this project's tooling expects
# to hold secrets. Never commit the filled-in .env.local — .env* (except this .example) must
# stay in .gitignore.
# Never put any of these values directly into CLAUDE.md, SETUP_CHECKLIST.md, or any file under .claude/skills/ —
# those files get copied wholesale across projects and are meant to be committed; this file is not.

# --- Dev/sandbox Supabase project (never the production project) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=

# --- AI-native features (Edge Functions calling model APIs) ---
# Use a restricted/test key where the provider supports it.
OPENAI_API_KEY=

# --- Add project-specific variables below, following the same rule: ---
# names/placeholders can be documented in CLAUDE.md, real values only ever go here.
